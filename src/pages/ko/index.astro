---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildPodcastSeriesJsonLd, buildPodcastEpisodeJsonLd, resolveEpisodeThumbnail } from '../../lib/seo';

const episodes = await getCollection('episodes', ({ data }) => data.lang === 'ko');
const sortedEpisodes = episodes.sort((a, b) => b.data.episodeNumber - a.data.episodeNumber);

const [featured, ...rest] = sortedEpisodes;
const site = Astro.site?.toString() ?? 'https://aifrontier.kr';

// #1: 동적 meta description — 최신 에피소드 제목+description 포함 (160자 제한)
const baseBrand = 'AI Frontier - AI 심층 대화 팟캐스트';
const description = featured
  ? `최신: EP ${featured.data.episodeNumber}. ${featured.data.title} — ${featured.data.description}`.slice(0, 155) + '… | AI Frontier'
  : baseBrand;

// #3: PodcastSeries + PodcastEpisode JSON-LD
const seriesJsonLd = buildPodcastSeriesJsonLd({
  site,
  lang: 'ko',
  name: 'AI Frontier',
  description: baseBrand,
});
const jsonLd = featured
  ? [
      seriesJsonLd,
      buildPodcastEpisodeJsonLd({
        site,
        lang: 'ko',
        episodeNumber: featured.data.episodeNumber,
        title: featured.data.title,
        description: featured.data.description,
        publishedAt: featured.data.publishedAt.toISOString().slice(0, 10),
        duration: featured.data.duration,
        youtubeId: featured.data.youtubeId,
        thumbnail: featured.data.thumbnail,
      }),
    ]
  : seriesJsonLd;
---

<BaseLayout
  title="AI Frontier"
  description={description}
  lang="ko"
  canonicalPath="/ko"
  alternatePath="/en"
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <p class="text-center text-gray-600 dark:text-gray-400 mb-8">
      노정석, 최승준, 김성현이 인공지능의 최신 기술·산업·철학을 깊이 있게 이야기합니다.
    </p>
    {featured && (
      <section class="mb-12">
        <a href={`/ko/episodes/ep${featured.data.episodeNumber}`} class="block group">
          <article class="border border-gray-200 dark:border-gray-800 rounded-xl overflow-hidden hover:border-primary-500 transition-colors">
            {featured.data.thumbnail && (
              <div class="aspect-video bg-gray-100 dark:bg-gray-900 overflow-hidden">
                <img
                  src={resolveEpisodeThumbnail({ thumbnail: featured.data.thumbnail, youtubeId: featured.data.youtubeId }) ?? featured.data.thumbnail}
                  alt={featured.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="eager"
                />
              </div>
            )}
            <div class="p-6">
              <p class="text-sm font-medium text-primary-600 dark:text-primary-400 mb-2">
                EP {featured.data.episodeNumber}
              </p>
              <h2 class="text-2xl font-bold mb-2 group-hover:text-primary-600 transition-colors">
                {featured.data.title}
              </h2>
              {/* #2: description + 게스트/호스트 텍스트 */}
              <p class="text-gray-600 dark:text-gray-400 text-sm mb-3 line-clamp-3">
                {featured.data.description}
              </p>
              <div class="flex flex-wrap gap-x-4 text-sm text-gray-500 dark:text-gray-400">
                <span>{featured.data.publishedAt.toLocaleDateString('ko-KR')} · {featured.data.duration}</span>
                {featured.data.hosts.length > 0 && (
                  <span>호스트: {featured.data.hosts.join(', ')}</span>
                )}
                {featured.data.guests.length > 0 && (
                  <span>게스트: {featured.data.guests.join(', ')}</span>
                )}
              </div>
            </div>
          </article>
        </a>
      </section>
    )}

    {rest.length > 0 && (
      <section>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {rest.map((episode) => (
            <a href={`/ko/episodes/ep${episode.data.episodeNumber}`} class="block group">
              <article class="border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden hover:border-primary-500 transition-colors h-full">
                {episode.data.thumbnail && (
                  <div class="aspect-video bg-gray-100 dark:bg-gray-900 overflow-hidden">
                    <img
                      src={resolveEpisodeThumbnail({ thumbnail: episode.data.thumbnail, youtubeId: episode.data.youtubeId }) ?? episode.data.thumbnail}
                      alt={episode.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-4">
                  <p class="text-xs font-medium text-primary-600 dark:text-primary-400 mb-1">
                    EP {episode.data.episodeNumber}
                  </p>
                  <h3 class="font-semibold text-sm line-clamp-2 group-hover:text-primary-600 transition-colors">
                    {episode.data.title}
                  </h3>
                  {/* #5: 그리드에도 description 1줄 추가 */}
                  <p class="text-gray-500 dark:text-gray-400 text-xs mt-1 line-clamp-2">
                    {episode.data.description}
                  </p>
                  <p class="text-gray-500 dark:text-gray-400 text-xs mt-2">
                    {episode.data.publishedAt.toLocaleDateString('ko-KR')}
                  </p>
                </div>
              </article>
            </a>
          ))}
        </div>
      </section>
    )}

    {sortedEpisodes.length === 0 && (
      <div class="text-center py-16 text-gray-500 dark:text-gray-400">
        <p>아직 에피소드가 없습니다.</p>
      </div>
    )}
  </div>
</BaseLayout>
