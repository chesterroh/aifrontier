---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => data.lang === 'ko' && !data.draft);
const sortedArticles = articles.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout
  title="자료"
  description="AI Frontier 에피소드에서 사용한 발표 자료, 슬라이드, 아티클 모음"
  lang="ko"
  canonicalPath="/ko/articles"
  alternatePath="/en/articles"
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <header class="mb-8">
      <h1 class="text-2xl font-bold tracking-tight">자료</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        에피소드에서 사용한 발표 자료와 아티클을 모았습니다.
      </p>
    </header>

    {sortedArticles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sortedArticles.map((article) => (
          <ArticleCard article={article} lang="ko" />
        ))}
      </div>
    ) : (
      <div class="text-center py-16 text-gray-500 dark:text-gray-400">
        <p>아직 자료가 없습니다.</p>
      </div>
    )}
  </div>
</BaseLayout>
