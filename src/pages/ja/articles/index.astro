---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => data.lang === 'ja' && !data.draft);
const sortedArticles = articles.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout
  title="資料"
  description="AI Frontierのエピソードで使用した発表資料・記事のアーカイブ"
  lang="ja"
  canonicalPath="/ja/articles"
  alternatePath="/ko/articles"
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <header class="mb-8">
      <h1 class="text-2xl font-bold tracking-tight">資料</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        エピソードで使用した発表資料と記事のアーカイブです。
      </p>
    </header>

    {sortedArticles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sortedArticles.map((article) => (
          <ArticleCard article={article} lang="ja" />
        ))}
      </div>
    ) : (
      <div class="text-center py-16 text-gray-500 dark:text-gray-400">
        <p>まだ資料がありません。</p>
      </div>
    )}
  </div>
</BaseLayout>
