---
import { extractSeriesNumber, type Series } from '../lib/episodes';

interface Props {
  currentLang: 'ko' | 'en' | 'ja' | 'zh-Hans';
  alternateSlug?: string | null;
  currentSlug?: string;
  articleTranslations?: Array<'ko' | 'en' | 'ja' | 'zh-Hans'>;
  series?: Series;
}

const {
  currentLang,
  alternateSlug,
  currentSlug,
  articleTranslations = [],
  series = 'main',
} = Astro.props;
const seriesSection = series === 'interview' ? 'interviews' : 'episodes';

const languages = [
  { code: 'ko', label: '한국어' },
  { code: 'en', label: 'English' },
  { code: 'ja', label: '日本語' },
  { code: 'zh-Hans', label: '中文' },
] as const;

function getAlternateUrl(langCode: string): string {
  if (langCode === currentLang) {
    return '#';
  }

  // If alternate version exists and target is ko/en pair, link to it
  const alternateNumber = alternateSlug ? extractSeriesNumber(alternateSlug) : null;
  if (alternateNumber != null && ((currentLang === 'ko' && langCode === 'en') || (currentLang === 'en' && langCode === 'ko'))) {
    const segment = seriesSection === 'episodes' ? `ep${alternateNumber}` : String(alternateNumber);
    return `/${langCode}/${seriesSection}/${segment}`;
  }

  // Otherwise, go to language home
  return `/${langCode}`;
}
---

<div class="relative inline-block">
  <select
    id="lang-switcher"
    class="appearance-none bg-transparent border border-gray-300 dark:border-gray-700 rounded-md px-3 py-1.5 pr-8 text-sm cursor-pointer hover:border-gray-400 dark:hover:border-gray-600 focus:outline-none focus:ring-2 focus:ring-primary-500"
    data-current-lang={currentLang}
    data-alternate-slug={alternateSlug || ''}
    data-current-slug={currentSlug || ''}
    data-article-translations={articleTranslations.join(',')}
    data-series-section={seriesSection}
  >
    {languages.map((lang) => (
      <option value={lang.code} selected={lang.code === currentLang}>
        {lang.label}
      </option>
    ))}
  </select>
  <div class="absolute inset-y-0 right-0 flex items-center pr-2 pointer-events-none">
    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</div>

<script>
  import { extractSeriesNumber } from '../lib/episodes';

  const switcher = document.getElementById('lang-switcher') as HTMLSelectElement;
  if (switcher) {
    switcher.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      const newLang = target.value;
      const currentLang = switcher.dataset.currentLang;
      const alternateSlug = switcher.dataset.alternateSlug;
      const currentSlug = switcher.dataset.currentSlug;
      const articleTranslations = new Set(
        (switcher.dataset.articleTranslations || '').split(',').filter(Boolean),
      );
      const seriesSection = switcher.dataset.seriesSection || 'episodes';
      // alternateSlug는 "ep83"/"interview1"/"1" 등 접두사 유무가 섞여 올 수 있으므로 숫자만 뽑아
      // 대상 섹션(episodes -> ep{n}, interviews -> {n})에 맞는 URL 세그먼트로 재구성한다.
      const alternateNumber = alternateSlug ? extractSeriesNumber(alternateSlug) : null;
      const alternateSegment = alternateNumber != null
        ? (seriesSection === 'episodes' ? `ep${alternateNumber}` : String(alternateNumber))
        : null;

      if (newLang === currentLang) return;

      // Get current path
      const path = window.location.pathname;

      // Check if we're on an episode or interview detail page
      const episodeMatch = path.match(/\/(?:ko|en|ja|zh-Hans)\/(episodes|interviews)\/([^\/]+)/);
      const articleDetailMatch = path.match(/\/(?:ko|en|ja|zh-Hans)\/articles\/(.+?)\/?$/);
      const articlesMatch = path.match(/\/(?:ko|en|ja|zh-Hans)\/articles(?:\/|$)/);
      const interviewsListMatch = path.match(/\/(?:ko|en|ja|zh-Hans)\/interviews\/?$/);

      if (episodeMatch && alternateSegment && ((currentLang === 'ko' && newLang === 'en') || (currentLang === 'en' && newLang === 'ko'))) {
        // Navigate to alternate episode/interview (ko<->en only)
        window.location.href = `/${newLang}/${seriesSection}/${alternateSegment}`;
      } else if (episodeMatch) {
        // Same slug for ja/zh-Hans
        window.location.href = `/${newLang}/${episodeMatch[1]}/${episodeMatch[2]}`;
      } else if (interviewsListMatch) {
        // Interview list page: go to same list in the target language
        window.location.href = `/${newLang}/interviews`;
      } else if (articleDetailMatch && currentSlug && articleTranslations.has(newLang)) {
        // Same-slug article translation exists
        window.location.href = `/${newLang}/articles/${currentSlug}`;
      } else if (articlesMatch) {
        // Articles: translations aren't guaranteed, so land on the target-language list
        window.location.href = `/${newLang}/articles`;
      } else {
        // Navigate to language home
        window.location.href = `/${newLang}`;
      }
    });
  }
</script>
