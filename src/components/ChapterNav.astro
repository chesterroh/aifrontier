---
interface Chapter {
  time: string;
  title: string;
}

interface Props {
  chapters: Chapter[];
  // 배지 텍스트는 호출부(EpisodeLayout)가 episodeLabel(lang, {series, episodeNumber})로 계산해 넘긴다.
  // "EP {n}"을 여기서 하드코딩하지 않아야 인터뷰 시리즈("인터뷰 {n}" 등)에서도 올바르게 표시된다.
  episodeLabel?: string;
  episodeTitle?: string;
}

const { chapters, episodeLabel, episodeTitle } = Astro.props;
---

{chapters.length > 0 && (
  <nav class="chapter-nav border border-gray-200 dark:border-gray-800 rounded-lg p-4 my-6 lg:my-0">
    {episodeLabel && episodeTitle && (
      <div class="mb-4 pb-3 border-b border-gray-200 dark:border-gray-700">
        <p class="text-xs font-medium text-primary-600 dark:text-primary-400 mb-1">{episodeLabel}</p>
        <h2 class="text-sm font-bold text-gray-900 dark:text-gray-100 leading-snug">{episodeTitle}</h2>
      </div>
    )}
    <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">
      챕터
    </h3>
    <ul class="space-y-0.5">
      {chapters.map((chapter) => (
        <li class="flex items-center gap-1">
          <button
            type="button"
            data-timestamp={chapter.time}
            class="flex-1 text-left px-2 py-1.5 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors group cursor-pointer"
          >
            <span class="block text-xs font-mono text-gray-400 dark:text-gray-500 group-hover:text-primary-600 dark:group-hover:text-primary-400">
              {chapter.time}
            </span>
            <span class="block text-sm text-gray-700 dark:text-gray-200 group-hover:text-primary-700 dark:group-hover:text-primary-300 leading-snug">
              {chapter.title}
            </span>
          </button>
          <button
            type="button"
            data-play-timestamp={chapter.time}
            class="flex-shrink-0 p-1.5 rounded-md text-gray-400 dark:text-gray-500 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors cursor-pointer"
            title="재생"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </button>
        </li>
      ))}
    </ul>
  </nav>
)}
