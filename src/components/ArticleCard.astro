---
import type { CollectionEntry } from 'astro:content';
import { articleSlug } from '../lib/articles';

interface Props {
  article: CollectionEntry<'articles'>;
  lang: 'ko' | 'en' | 'ja' | 'zh-Hans';
}

const { article, lang } = Astro.props;
const { data } = article;
const href = `/${lang}/articles/${articleSlug(article)}`;
const localeMap: Record<string, string> = { ko: 'ko-KR', en: 'en-US', ja: 'ja-JP', 'zh-Hans': 'zh-CN' };
const formattedDate = data.publishedAt.toLocaleDateString(localeMap[lang] ?? 'en-US');
---

<a href={href} class="block group">
  <article class="border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden hover:border-primary-500 transition-colors h-full">
    {data.heroImage ? (
      <div class="aspect-video bg-gray-100 dark:bg-gray-900 overflow-hidden">
        <img
          src={data.heroImage}
          alt={data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="aspect-video bg-gray-100 dark:bg-gray-900 flex items-center justify-center text-gray-300 dark:text-gray-700">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
      </div>
    )}
    <div class="p-4">
      <div class="flex flex-wrap items-center gap-2 mb-1">
        {data.episodeNumber != null && (
          <span class="text-xs font-medium text-primary-600 dark:text-primary-400">
            EP {data.episodeNumber}
          </span>
        )}
        {data.tags.map((tag) => (
          <span class="text-xs px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">
            {tag}
          </span>
        ))}
      </div>
      <h3 class="font-semibold line-clamp-2 group-hover:text-primary-600 transition-colors">
        {data.title}
      </h3>
      <p class="text-gray-500 dark:text-gray-400 text-xs mt-1 line-clamp-2">
        {data.description}
      </p>
      <p class="text-gray-500 dark:text-gray-400 text-xs mt-2">
        {formattedDate}
      </p>
    </div>
  </article>
</a>
