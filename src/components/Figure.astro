---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  href?: string;
}
const { src, alt, caption, href = src } = Astro.props;
---

<figure class="article-figure">
  <a href={href} target="_blank" rel="noopener noreferrer">
    <img src={src} alt={alt} loading="lazy" decoding="async" />
  </a>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .article-figure {
    margin: 1.75rem 0;
  }

  .article-figure img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }

  .article-figure figcaption {
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: #6b7280;
    text-align: center;
  }

  @media (prefers-color-scheme: dark) {
    .article-figure img {
      border-color: #374151;
    }

    .article-figure figcaption {
      color: #9ca3af;
    }
  }
</style>
